{
  "extends": "../../tsconfig.base.json",
  "include": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts", "vite.config.ts"],
  "references": [
    { "path": "../../packages/core" },
    { "path": "../../packages/mcp-registry" },
    { "path": "../../packages/executor" },
    { "path": "../../packages/code-mode" }
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "allowArbitraryExtensions": true,
    "rootDir": ".",
    "outDir": "dist",
    "paths": {
      "@/*": ["./src/client/*"]
    }
  }
}
