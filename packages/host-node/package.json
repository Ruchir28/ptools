{
  "name": "@ptools/host-node",
  "version": "0.1.0-alpha.0",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ruchir28/ptools.git",
    "directory": "packages/host-node"
  },
  "homepage": "https://github.com/Ruchir28/ptools#readme",
  "bugs": {
    "url": "https://github.com/Ruchir28/ptools/issues"
  },
  "files": [
    "dist/*.js",
    "dist/*.js.map",
    "dist/*.d.ts",
    "dist/*.d.ts.map",
    "dist/**/*.d.ts.map",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "imports": {
    "#sandbox-worker": "./dist/executor/sandbox-worker.js"
  },
  "scripts": {
    "build": "pnpm --filter @ptools/executor build && tsc -p tsconfig.json && pnpm build:worker",
    "build:worker": "node scripts/build-sandbox-worker.mjs",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "pnpm --filter @ptools/executor build && pnpm build:worker && vitest run --exclude \"**/dist/**\""
  },
  "devDependencies": {
    "esbuild": "^0.27.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "@ptools/auth": "workspace:*",
    "@ptools/code-mode": "workspace:*",
    "@ptools/code-mode-api": "workspace:*",
    "@ptools/config": "workspace:*",
    "@ptools/executor": "workspace:*",
    "@ptools/mcp-registry": "workspace:*",
    "effect": "3.21.2"
  }
}
