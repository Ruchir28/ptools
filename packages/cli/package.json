{
  "name": "@ptools/cli",
  "version": "0.1.0-alpha.0",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ruchir28/ptools.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Ruchir28/ptools#readme",
  "bugs": {
    "url": "https://github.com/Ruchir28/ptools/issues"
  },
  "bin": {
    "ptools": "./dist/cli.js"
  },
  "files": [
    "dist/*.js",
    "dist/*.js.map",
    "dist/*.d.ts",
    "dist/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "mcp:serve": "tsx src/cli.ts mcp serve",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run --exclude \"**/dist/**\""
  },
  "dependencies": {
    "@ptools/host-node": "workspace:*",
    "@ptools/mcp-server": "workspace:*",
    "effect": "3.21.2"
  }
}
