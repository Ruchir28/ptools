{
  "name": "@p_tools/agent-tools",
  "version": "0.1.0-alpha.0",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ruchir28/ptools.git",
    "directory": "packages/agent-tools"
  },
  "homepage": "https://github.com/Ruchir28/ptools#readme",
  "bugs": {
    "url": "https://github.com/Ruchir28/ptools/issues"
  },
  "files": [
    "dist/*.js",
    "dist/*.js.map",
    "dist/*.d.ts",
    "dist/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ai-sdk": {
      "types": "./dist/ai-sdk.d.ts",
      "default": "./dist/ai-sdk.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run --exclude \"**/dist/**\""
  },
  "dependencies": {
    "@p_tools/code-mode": "workspace:*",
    "@p_tools/core": "workspace:*",
    "@p_tools/executor": "workspace:*",
    "@p_tools/mcp-registry": "workspace:*",
    "ai": "6.0.184",
    "effect": "3.21.2",
    "zod": "4.4.3"
  }
}
