{
  "name": "@ptools/host-cloudflare",
  "version": "0.1.0-alpha.0",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ruchir28/ptools.git",
    "directory": "packages/host-cloudflare"
  },
  "homepage": "https://github.com/Ruchir28/ptools#readme",
  "bugs": {
    "url": "https://github.com/Ruchir28/ptools/issues"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker/index.d.ts",
      "default": "./dist/worker/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "pnpm run test:node && pnpm run test:worker",
    "test:node": "vitest run test/import-boundary.test.ts",
    "test:worker": "vitest run --config vitest.worker.config.ts"
  },
  "dependencies": {
    "@cloudflare/workers-types": "4.20260607.1",
    "@ptools/code-mode-api": "workspace:*",
    "effect": "3.21.2",
    "hono": "^4.12.23"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.16.6"
  }
}
