{
  "name": "@ptools/host-cloudflare",
  "version": "0.1.0-alpha.0",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ruchir28/ptools.git",
    "directory": "packages/host-cloudflare"
  },
  "homepage": "https://github.com/Ruchir28/ptools#readme",
  "bugs": {
    "url": "https://github.com/Ruchir28/ptools/issues"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker/index.d.ts",
      "default": "./dist/worker/index.js"
    },
    "./layers": {
      "types": "./dist/layers/index.d.ts",
      "default": "./dist/layers/index.js"
    },
    "./layers/executor": {
      "types": "./dist/layers/executor.d.ts",
      "default": "./dist/layers/executor.js"
    }
  },
  "scripts": {
    "build": "pnpm --filter @ptools/executor build && pnpm build:dynamic-worker-source && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "pnpm run test:node && pnpm run test:worker",
    "test:node": "vitest run test/import-boundary.test.ts test/mcpConnector.test.ts test/platform.test.ts test/provider.test.ts test/dynamicWorkerExecutor.test.ts test/codeModeServer.test.ts",
    "test:worker": "vitest run --config vitest.worker.config.ts",
    "build:dynamic-worker-source": "node scripts/build-dynamic-worker-source.mjs"
  },
  "dependencies": {
    "@cloudflare/workers-types": "4.20260607.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@ptools/auth": "workspace:*",
    "@ptools/code-mode": "workspace:*",
    "@ptools/code-mode-api": "workspace:*",
    "@ptools/config": "workspace:*",
    "@ptools/mcp-registry": "workspace:*",
    "effect": "3.21.2",
    "hono": "^4.12.23",
    "@ptools/executor": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.16.6",
    "esbuild": "^0.28.0",
    "zod": "4.4.3"
  }
}
