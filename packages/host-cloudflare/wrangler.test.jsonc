{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ptools-host-cloudflare-test",
  "main": "./test/worker-entry.ts",
  "compatibility_date": "2026-05-22",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "PTOOLS_PUBLIC_ACCESS_TOKEN": "test-public-token"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "PTOOLS_CODE_MODE",
        "class_name": "TestCodeModeObject"
      }
    ]
  },
  "worker_loaders": [
    {
      "binding": "PTOOLS_EXECUTION_LOADER"
    }
  ],
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["TestCodeModeObject"]
    }
  ]
}
