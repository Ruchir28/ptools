{
  "name": "ptools",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "pnpm --filter @ptools/server dev",
    "playground": "tsx apps/playground/src/playground.ts",
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty && pnpm --recursive --if-present typecheck",
    "test": "vitest run --exclude \"**/dist/**\""
  },
  "dependencies": {
    "effect": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "prettier": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=22"
  }
}
