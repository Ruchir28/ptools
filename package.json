{
  "name": "ptools",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "prepare": "effect-language-service patch",
    "dev": "pnpm --filter @ptools/cli dev -- mcp serve --host node",
    "playground": "tsx apps/playground/src/playground.ts",
    "build": "tsc -b && pnpm --filter @ptools/host-node build:worker",
    "typecheck": "tsc -b --pretty && pnpm --recursive --if-present typecheck",
    "test": "vitest run --exclude \"**/dist/**\" --exclude \"packages/host-cloudflare/test/worker.test.ts\" && pnpm --filter @ptools/host-cloudflare test:worker",
    "check:publishable": "node scripts/check-publishable-packages.mjs && node scripts/check-packed-artifacts.mjs",
    "pack:dry-run": "node scripts/check-packed-artifacts.mjs",
    "smoke:packed-install": "node scripts/smoke-packed-install.mjs"
  },
  "dependencies": {
    "effect": "3.21.2"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@types/node": "25.9.1",
    "deno": "2.8.3",
    "prettier": "3.8.3",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=22"
  }
}
